# 1. Жесткая блокировка доступа к конфиденциальным файлам
<FilesMatch "^\.env|sql\.zip$|composer\.(json|lock)|package\.json|artisan">
    Order allow,deny
    Deny from all
</FilesMatch>

# 2. Запрет на просмотр структуры директорий (если индексного файла нет)
Options -Indexes

# 3. Ваше существующее правило перенаправления в public
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Если запрос не к существующему файлу или директории, перенаправляем его в public/
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>
